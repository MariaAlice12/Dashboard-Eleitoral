generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Deputado {
  id                 Int          @id
  nome               String
  nomeCivil          String?
  siglaPartido       String
  siglaUf            String
  urlFoto            String
  email              String?
  situacao           String?
  condicaoEleitoral  String?
  updatedAt          DateTime     @updatedAt
  proposicoes        Proposicao[]

  @@index([siglaPartido])
  @@index([siglaUf])
}

model Proposicao {
  id                Int      @id
  idDeputadoAutor   Int
  deputado          Deputado @relation(fields: [idDeputadoAutor], references: [id])
  siglaTipo         String
  numero            Int
  ano               Int
  ementa            String
  areaId            String
  dataApresentacao  DateTime?
  updatedAt         DateTime @updatedAt

  @@index([idDeputadoAutor])
  @@index([areaId])
}

model IngestaoLog {
  id                      Int       @id @default(autoincrement())
  executadoEm             DateTime  @default(now())
  status                  String
  deputadosProcessados    Int       @default(0)
  proposicoesProcessadas  Int       @default(0)
  erro                    String?
}

// Linha única (id fixo = 1) que guarda o progresso da sincronização em lotes,
// já que cada execução do cron processa só um trecho dos deputados para
// caber no limite de duração da função serverless.
model SyncState {
  id                      Int       @id @default(1)
  cursorDeputadoId        Int?
  deputadosProcessados    Int       @default(0)
  proposicoesProcessadas  Int       @default(0)
}
